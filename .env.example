# ─── Shopify Storefront API ───────────────────────────────────────────────────
# Public storefront access token (read-only scoped)
# Store: rackzone.ie — IE/EUR only at launch
VITE_SHOPIFY_STOREFRONT_URL=https://your-store.myshopify.com/api/2024-04/graphql.json
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-public-access-token

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Tables: layouts, presets — RLS policies required on both
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
